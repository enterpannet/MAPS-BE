# Database - Docker: docker compose up -d
DATABASE_URL=postgres://maps:maps@localhost:5432/maps

# Redis - Docker
REDIS_URL=redis://localhost:6379

# JWT - ใช้อย่างน้อย 32 ตัวอักษร
JWT_SECRET=your-256-bit-secret-key-change-in-production

# Server
PORT=3001

# แหล่งข้อมูลปั๊มน้ำมัน (ถ้าไม่ใส่จะใช้แค่ OpenStreetMap)
# NREL - สหรัฐฯ ปั๊มพลังงานทางเลือก (EV, CNG, etc.) https://developer.nrel.gov/signup
NREL_API_KEY=
# Open Charge Map - สถานีชาร์จ EV ทั่วโลก https://openchargemap.org/site/develop/api
OCM_API_KEY=
# Tankerkoenig - เยอรมนี ปั๊มน้ำมัน+ราคา https://creativecommons.tankerkoenig.de/
TANKERKOENIG_API_KEY=

# Gemini - สร้างโจทย์/ข้อมูลศึกษา หน้า ฝึกภาษา Rust (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
